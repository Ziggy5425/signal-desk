# Copy to .env (gitignored) and fill. TEST MODE ONLY.
# Your Stripe TEST secret key — must start with sk_test_ (never sk_live_).
STRIPE_SECRET_KEY=sk_test_xxx

# Set to 1 to run the loop with a stubbed payment (no Stripe call); 0 to use real test-mode Stripe.
STRIPE_SKILLS_DEV=0

# Nemotron 3 Ultra (cloud reasoning lane) — OpenAI-compatible.
NVIDIA_API_KEY=nvapi-xxx
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1
NEMOTRON_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Clock Out Capital screener (real signal engine) — loopback.
SCREENER_API_URL=http://localhost:8001
